<?xml version="1.0" encoding="UTF-8"?><record_update sys_domain="global" table="sys_script_client">
    <sys_script_client action="DELETE">
        <active>true</active>
        <applies_extended>false</applies_extended>
        <condition/>
        <description>Calling the company on change of user name</description>
        <field>caller_id</field>
        <global>true</global>
        <isolate_script>true</isolate_script>
        <messages>adding client script for populating company on change of caller field</messages>
        <name>Company_calling</name>
        <order/>
        <script><![CDATA[function onChange(control, oldValue, newValue, isLoading, isTemplate) {
   if (newValue === '') {
      return;
   }
   
	// creating an object of GlideAjax
  var getCompanyName = new GlideAjax('GetCompany');
	
  // Specify the getCompany method
  getCompany.addParam('sysparm_name','getCompany');
  // Pass the Requested for sys_id
  getCompany.addParam('sysparm_userID', g_form.getValue('u_requested_for'));
  // Send the request to the server
  getCompany.getXML(populateCompanyField);


  // When the response is back from the server
  function populateCompanyField(response){
    // Extract the email address from the response, clear any value from the email field, 
    // set new value in the email field
    var companyNameFromScriptInclude = response.responseXML.documentElement.getAttribute("answer");
    g_form.clearValue('u_requested_for_companyName');
    g_form.setValue('u_requested_for_companyName',companyNameFromScriptInclude);
  }
	
 
}
]]></script>
