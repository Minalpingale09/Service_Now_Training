        <field>priority</field>
        <global>true</global>
        <isolate_script>true</isolate_script>
        <messages/>
        <name>Employee Id</name>
        <order/>
        <script><![CDATA[function onChange(control, oldValue, newValue, isLoading, isTemplate) {

  // Modified the if to return if the newValue == oldValue to avoid
  // unecessary trips to the server
  if (isLoading || newValue === '' || newValue == oldValue) {
    return;
  }

  // Instantiate the GetEmailAddress Script Include 
  var getEmpId = new GlideAjax('GetEmployeeId');
  // Specify the getEmail method
 getEmpId.addParam('sysparm_name','getEmpId');
  // Pass the Requested for sys_id
  getEmpId.addParam('sysparm_userID', g_form.getValue('priority'));
  // Send the request to the server
  getEmpId.getXML(populateEmailField);


  // When the response is back from the server
  function populateEmailField(response){
    // Extract the email address from the response, clear any value from the email field, 
    // set new value in the email field
    var emailFromScriptInclude = response.responseXML.documentElement.getAttribute("answer");
    g_form.clearValue('priority');
    g_form.setValue('priority',emailFromScriptInclude);
  }
}]]></script>
